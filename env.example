# Policy Factory — Environment Configuration
#
# Copy this file to .env and fill in the values.
# The application looks for .env in these locations (first found wins):
#   1. Current working directory (./.env)
#   2. Project root (development mode)
#   3. User config directory (~/.config/policy-factory/.env)

# --- AI Agent Operations ---
# The agent framework uses two backends:
#
# 1. Claude CLI (via claude-agent-sdk) — for roles needing MCP file tools
#    (generator, critic, seed, heartbeat-sa-update).
#    Requires ANTHROPIC_API_KEY for authentication.
# ANTHROPIC_API_KEY=sk-ant-...your-key-here...
#
# 2. Gemini Flash (via google-genai) — for cheap text/search tasks
#    (heartbeat skim/triage, classifier, synthesis, ideas, values-seed).
#    Requires GOOGLE_API_KEY for authentication.
# GOOGLE_API_KEY=AIza...your-key-here...

# --- Authentication (REQUIRED) ---
# Secret key for signing JWT tokens. Must be set before starting the server.
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-long-random-string

# How long JWT tokens are valid, in hours (optional, defaults to 24)
# JWT_EXPIRY_HOURS=24

# --- Database ---
# SQLite database file path (defaults to ~/.policy-factory/store.db)
# POLICY_FACTORY_DB_PATH=~/.policy-factory/store.db

# --- Server ---
# Host and port are typically set via CLI arguments (--host, --port)
# but can also be set here as defaults.
# POLICY_FACTORY_HOST=127.0.0.1
# POLICY_FACTORY_PORT=8765
